{
  "name": "regression-code",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "test:score": "tsx ./dev/test_score.ts",
    "test:parse": "tsx ./dev/test_parse.ts",
    "test:edit": "tsx ./dev/test_edit.ts",
    "test:layout": "tsx ./dev/test_layout_apply.ts",
    "test:analyze": "tsx ./dev/test_analyze.ts",
    "test:track": "tsx ./dev/test_track.ts",
    "test:view": "tsx ./dev/test_view.ts",
    "test:audio": "tsx ./dev/test_audio.ts",
    "inspect:sheet": "node --experimental-specifier-resolution=node ./src/dev/inspect_sheet.ts"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vite": "^8.0.14"
  }
}
